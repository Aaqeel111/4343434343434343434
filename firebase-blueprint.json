{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "The last time the user logged in." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role in the system." }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Represents a single conversation thread.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the session." },
        "userId": { "type": "string", "description": "The ID of the user who owns this session." },
        "title": { "type": "string", "description": "A summary or title for the conversation." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the session was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the session was last updated." },
        "isPdfMode": { "type": "boolean", "description": "Whether this session was in PDF mode." },
        "isSourceMode": { "type": "boolean", "description": "Whether this session was in Source mode." },
        "sources": { "type": "array", "items": { "type": "object" }, "description": "List of sources attached to this chat." },
        "pinned": { "type": "boolean", "description": "Whether this chat is pinned." }
      },
      "required": ["userId", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the message." },
        "role": { "type": "string", "enum": ["user", "model"], "description": "Who sent the message." },
        "content": { "type": "string", "description": "The text content of the message." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." },
        "attachments": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "data": { "type": "string" },
              "mimeType": { "type": "string" },
              "name": { "type": "string" }
            }
          }, 
          "description": "List of base64 image data or file info." 
        }
      },
      "required": ["role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "Chat",
      "description": "A user's chat sessions."
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific session."
    }
  }
}
